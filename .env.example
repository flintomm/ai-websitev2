# Required for cloud hosting
HOST=0.0.0.0
PORT=8080
NODE_ENV=production

# Comma-separated allowlist of frontend origins (required in production)
# Example: https://yourname.github.io
JAMF_AGENT_ALLOWED_ORIGINS=https://your-frontend-domain.example
SITE_CHAT_ALLOWED_ORIGINS=https://your-frontend-domain.example

# Optional request limit per IP per minute
JAMF_AGENT_RATE_LIMIT_MAX=30
SITE_CHAT_RATE_LIMIT_MAX=30

# Email gate mode: "mock" or "backend"
EMAIL_GATE_MODE=mock

# Optional webhook target when EMAIL_GATE_MODE=backend
EMAIL_GATE_WEBHOOK_URL=

# Optional: path to persisted JAMF RAG data (Railway volume)
# Example: /data/jamf-pro-docs
RAG_BASE_PATH=

# Optional: remote merged index JSON URL (replaces local volume/index files)
RAG_REMOTE_INDEX_URL=

# Optional: bearer token for protected remote index URL
RAG_REMOTE_INDEX_BEARER=

# Provider keys (set at least one provider)
KIMI_API_KEY=
MINIMAX_API_KEY=

# Optional provider base URLs
KIMI_BASE_URL=https://api.kimi.com/coding/
MINIMAX_BASE_URL=https://api.minimax.io/anthropic

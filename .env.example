# Server settings
HOST=0.0.0.0
PORT=8080
NODE_ENV=production

# Chatbot security / traffic controls
SITE_CHAT_ALLOWED_ORIGINS=https://your-frontend-domain.example
SITE_CHAT_RATE_LIMIT_MAX=30

# MiniMax provider (server-side only)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
SITE_CHAT_DEFAULT_MODEL=minimax/MiniMax-M2.1
